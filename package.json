{
  "name": "cdk-nag-validator",
  "displayName": "CDK NAG Validator",
  "description": "Run AWS cdk-nag rule packs against your CDK project from inside VS Code — AwsSolutions, HIPAA, NIST, PCI DSS, Serverless — and see findings in the Problems panel.",
  "version": "0.0.1",
  "publisher": "alphacrack",
  "private": false,
  "license": "MIT",
  "icon": "media/icon.png",
  "galleryBanner": {
    "color": "#232F3E",
    "theme": "dark"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/alphacrack/cdk-nag-extension"
  },
  "bugs": {
    "url": "https://github.com/alphacrack/cdk-nag-extension/issues"
  },
  "homepage": "https://github.com/alphacrack/cdk-nag-extension#readme",
  "keywords": [
    "aws",
    "cdk",
    "cdk-nag",
    "cloudformation",
    "security",
    "compliance",
    "hipaa",
    "nist",
    "pci-dss",
    "serverless",
    "linter"
  ],
  "badges": [
    {
      "url": "https://github.com/alphacrack/cdk-nag-extension/actions/workflows/ci.yml/badge.svg",
      "href": "https://github.com/alphacrack/cdk-nag-extension/actions/workflows/ci.yml",
      "description": "CI status"
    },
    {
      "url": "https://img.shields.io/github/license/alphacrack/cdk-nag-extension.svg",
      "href": "https://github.com/alphacrack/cdk-nag-extension/blob/main/LICENSE",
      "description": "License"
    }
  ],
  "engines": {
    "vscode": "^1.97.0"
  },
  "categories": [
    "Linters",
    "Other"
  ],
  "activationEvents": [
    "onLanguage:typescript",
    "onLanguage:javascript",
    "onCommand:cdk-nag-validator.validate",
    "onCommand:cdk-nag-validator.validateWorkspace",
    "onCommand:cdk-nag-validator.configureRules",
    "workspaceContains:**/cdk.json"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "cdk-nag-validator.validate",
        "title": "CDK NAG: Validate Current File"
      },
      {
        "command": "cdk-nag-validator.validateWorkspace",
        "title": "CDK NAG: Validate Workspace"
      },
      {
        "command": "cdk-nag-validator.configureRules",
        "title": "CDK NAG: Configure Rules"
      },
      {
        "command": "cdk-nag-validator.suppressFinding",
        "title": "CDK NAG: Suppress Finding for Workspace"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "cdk-nag-validator.suppressFinding",
          "when": "false"
        }
      ]
    },
    "chatParticipants": [
      {
        "id": "cdk-nag-validator.chat",
        "name": "cdk-nag",
        "fullName": "CDK NAG",
        "description": "Ask about AWS CDK / CloudFormation compliance findings surfaced by cdk-nag",
        "isSticky": true
      }
    ],
    "languageModelTools": [
      {
        "name": "cdkNag_validateFile",
        "displayName": "Validate CDK / CloudFormation file with cdk-nag",
        "modelDescription": "Runs the configured AWS cdk-nag rule packs against a CDK project file (TypeScript / JavaScript) or the workspace and returns a summary of findings. Use this when the user asks to validate, scan, or security-check a CDK / CloudFormation file. Input accepts a workspace-relative or absolute file path; omit to scope to the active editor.",
        "userDescription": "Validates a CDK file against the configured cdk-nag rule packs and returns findings.",
        "canBeReferencedInPrompt": true,
        "toolReferenceName": "cdkNagValidateFile",
        "tags": [
          "aws",
          "cdk",
          "cdk-nag",
          "security",
          "compliance"
        ],
        "inputSchema": {
          "type": "object",
          "properties": {
            "uri": {
              "type": "string",
              "description": "Absolute path or workspace-relative path to the CDK file to validate. If omitted, the tool falls back to the active editor's file."
            },
            "rulePacks": {
              "type": "array",
              "items": {
                "type": "string",
                "enum": [
                  "AwsSolutionsChecks",
                  "HIPAA.SecurityChecks",
                  "NIST.800-53.R4Checks",
                  "NIST.800-53.R5Checks",
                  "PCI.DSS.321Checks",
                  "ServerlessChecks"
                ]
              },
              "description": "Optional override — rule packs to apply for this invocation. Defaults to the user's cdkNagValidator.enabledRulePacks setting."
            }
          }
        }
      },
      {
        "name": "cdkNag_explainRule",
        "displayName": "Explain a cdk-nag rule",
        "modelDescription": "Returns curated metadata (rule name, severity, description, remediation snippet, documentation URL) for a cdk-nag rule id such as AwsSolutions-S1 or HIPAA.Security-S3BucketVersioningEnabled. Use when the user asks what a rule does, why something is flagged, or how to fix a specific rule id.",
        "userDescription": "Explains what a cdk-nag rule checks and how to remediate it.",
        "canBeReferencedInPrompt": true,
        "toolReferenceName": "cdkNagExplainRule",
        "tags": [
          "aws",
          "cdk",
          "cdk-nag",
          "docs"
        ],
        "inputSchema": {
          "type": "object",
          "properties": {
            "ruleId": {
              "type": "string",
              "description": "The cdk-nag rule identifier (e.g. AwsSolutions-S1, AwsSolutions-EC23, HIPAA.Security-S3BucketVersioningEnabled)."
            }
          },
          "required": [
            "ruleId"
          ]
        }
      }
    ],
    "configuration": {
      "title": "CDK NAG Validator",
      "properties": {
        "cdkNagValidator.enabledRulePacks": {
          "type": "array",
          "default": [
            "AwsSolutionsChecks"
          ],
          "description": "List of enabled CDK-NAG rule packs",
          "items": {
            "type": "string",
            "enum": [
              "AwsSolutionsChecks",
              "HIPAA.SecurityChecks",
              "NIST.800-53.R4Checks",
              "NIST.800-53.R5Checks",
              "PCI.DSS.321Checks",
              "ServerlessChecks"
            ]
          }
        },
        "cdkNagValidator.customRules": {
          "type": "array",
          "default": [],
          "description": "Custom CDK-NAG rules",
          "items": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string",
                "description": "Unique identifier for the rule"
              },
              "name": {
                "type": "string",
                "description": "Name of the rule"
              },
              "description": {
                "type": "string",
                "description": "Description of the rule"
              },
              "level": {
                "type": "string",
                "enum": [
                  "ERROR",
                  "WARNING",
                  "INFO"
                ],
                "description": "Severity level of the rule"
              },
              "resourceTypes": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "description": "AWS resource types this rule applies to"
              },
              "condition": {
                "type": "string",
                "description": "JavaScript condition to check"
              }
            }
          }
        },
        "cdkNagValidator.autoValidate": {
          "type": "boolean",
          "default": true,
          "description": "Automatically validate files on save"
        },
        "cdkNagValidator.autoInstall": {
          "type": "boolean",
          "default": false,
          "description": "Automatically run npm install in the workspace before each validation. Disabled by default — enable only if you want the extension to manage dependencies automatically."
        },
        "cdkNagValidator.showInlineSuggestions": {
          "type": "boolean",
          "default": true,
          "description": "Show inline suggestions for fixing issues"
        },
        "cdk-nag-validator.useProjectCdkNag": {
          "type": "boolean",
          "default": true,
          "description": "Use project's CDK-NAG installation if available"
        },
        "cdk-nag-validator.defaultRules": {
          "type": "object",
          "default": {
            "AwsSolutions": true,
            "HIPAA.Security": false,
            "NIST.800-53.R4": false,
            "PCI DSS 321": false
          },
          "description": "Default CDK-NAG rules to apply"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "test-watch": "tsc -watch -p ./ && npm run test",
    "lint": "eslint src --ext ts",
    "lint:fix": "eslint src --ext ts --fix",
    "test": "node --test src/test/runner-unit.mjs",
    "test:jest": "jest",
    "test:integration": "npm run compile && node out/test/runTest.js",
    "test:functional": "npm run compile && node --test src/test/functional/runner.test.mjs",
    "test:all": "npm run lint && npm run compile && npm test && npm run test:jest && npm run test:functional && npm run test:integration",
    "clean": "rimraf out",
    "package": "vsce package",
    "publish": "vsce publish",
    "prepare": "husky install"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "^25.6.0",
    "@types/vscode": "~1.97.0",
    "@typescript-eslint/eslint-plugin": "^5.30.0",
    "@typescript-eslint/parser": "^5.30.0",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.2.1",
    "eslint": "^8.13.0",
    "eslint-config-prettier": "^8.10.0",
    "eslint-plugin-prettier": "^4.2.1",
    "husky": "^9.1.7",
    "jest": "^30.3.0",
    "lint-staged": "^16.4.0",
    "mocha": "^11.7.5",
    "prettier": "^2.8.8",
    "rimraf": "^6.1.3",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "typescript": "^4.7.2"
  },
  "dependencies": {
    "aws-cdk-lib": "^2.250.0",
    "cdk-nag": "^2.37.55",
    "yaml": "^2.3.4"
  },
  "overrides": {
    "brace-expansion": "^2.1.0"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  }
}
