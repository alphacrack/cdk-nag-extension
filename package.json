{
  "name": "cdk-nag-validator",
  "displayName": "CDK NAG Validator",
  "description": "VS Code extension for CDK-NAG validation with inline suggestions",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.96.2"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onLanguage:typescript",
    "onLanguage:javascript"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "cdk-nag-validator.validate",
        "title": "CDK NAG: Validate Current File"
      },
      {
        "command": "cdk-nag-validator.configureRules",
        "title": "CDK NAG: Configure Rules"
      }
    ],
    "configuration": {
      "title": "CDK NAG Validator",
      "properties": {
        "cdkNagValidator.enabledRulePacks": {
          "type": "array",
          "default": ["AwsSolutionsChecks"],
          "description": "List of enabled CDK-NAG rule packs",
          "items": {
            "type": "string",
            "enum": [
              "AwsSolutionsChecks",
              "HIPAA.SecurityChecks",
              "NIST.800-53.R4Checks",
              "NIST.800-53.R5Checks",
              "PCI.DSS.321Checks",
              "ServerlessChecks"
            ]
          }
        },
        "cdkNagValidator.customRules": {
          "type": "array",
          "default": [],
          "description": "Custom CDK-NAG rules",
          "items": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string",
                "description": "Unique identifier for the rule"
              },
              "name": {
                "type": "string",
                "description": "Name of the rule"
              },
              "description": {
                "type": "string",
                "description": "Description of the rule"
              },
              "level": {
                "type": "string",
                "enum": ["ERROR", "WARNING", "INFO"],
                "description": "Severity level of the rule"
              },
              "resourceTypes": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "description": "AWS resource types this rule applies to"
              },
              "condition": {
                "type": "string",
                "description": "JavaScript condition to check"
              }
            }
          }
        },
        "cdkNagValidator.autoValidate": {
          "type": "boolean",
          "default": true,
          "description": "Automatically validate files on save"
        },
        "cdkNagValidator.showInlineSuggestions": {
          "type": "boolean",
          "default": true,
          "description": "Show inline suggestions for fixing issues"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js"
  },
  "devDependencies": {
    "@types/vscode": "^1.60.0",
    "@types/node": "^16.11.7",
    "@typescript-eslint/eslint-plugin": "^5.30.0",
    "@typescript-eslint/parser": "^5.30.0",
    "eslint": "^8.13.0",
    "typescript": "^4.7.2"
  },
  "dependencies": {
    "aws-cdk-lib": "^2.156.0",
    "cdk-nag": "^2.27.0",
    "yaml": "^2.3.4"
  }
} 